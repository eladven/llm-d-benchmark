{# ============================================================================
   23_wva-namespace.yaml.j2

   Namespace manifest for WVA with the OpenShift user-monitoring label.
   This label is required so that user-workload-monitoring can discover
   and scrape WVA metrics in this namespace.

   Namespaced-mode WVA uses `wva.namespace` (which defaults to the model
   namespace). `kubectl apply` against this manifest is idempotent — if
   the namespace already exists from step_05, the label is simply merged.

   Also includes ServiceAccount + ClusterRoleBinding for KEDA's bearer token
   access to Prometheus/Thanos. These are created per-namespace and suffixed
   to support multi-tenant deployments (multiple WVA namespaces in one cluster).

   Only rendered when wva.enabled is true.
   ============================================================================ #}
{% if wva is defined and wva.enabled | default(false) %}
{% set wva_ns = wva.namespace | default(namespace.name, true) %}
apiVersion: v1
kind: Namespace
metadata:
  name: {{ wva_ns }}
  labels:
    openshift.io/user-monitoring: "true"
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: wva-prometheus-auth
  namespace: {{ wva_ns }}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: allow-thanos-querier-api-access-{{ wva_ns }}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: allow-thanos-querier-api-access
subjects:
- kind: ServiceAccount
  name: wva-prometheus-auth
  namespace: {{ wva_ns }}
{% endif %}
