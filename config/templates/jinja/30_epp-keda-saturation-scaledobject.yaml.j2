{# ============================================================================
   30_epp-keda-saturation-scaledobject.yaml.j2

   Per-stack KEDA ScaledObject for direct EPP saturation autoscaling.
   KEDA queries Prometheus for pool-average metrics (KV cache utilization
   and queue depth) and scales the Deployment accordingly.

   No WVA controller, no VariantAutoscaling, no prometheus-adapter.
   Just dual Prometheus triggers → HPA.

   PROMETHEUS QUERY PROXY:
   =======================
   This template uses a local prometheus-proxy deployment (24_prometheus-proxy.yaml.j2)
   running in the openshift-keda namespace. The proxy:

     - Listens on http://prometheus-proxy.openshift-keda:8080
     - Uses the KEDA operator's projected ServiceAccount token for authentication
     - Forwards queries to the cluster's Prometheus (thanos-querier)
     - Avoids kube-rbac-proxy 401 Unauthorized errors that occur with external bearer tokens

   The prometheus-proxy URL is CONFIGURABLE via eppKedaSaturation.prometheus.proxyUrl
   in the scenario/config. Default: "http://prometheus-proxy.openshift-keda:8080"

   WHY NOT USE TRADITIONAL BEARER TOKENS?
   ======================================
   On OpenShift 4.19+, the cluster-monitoring-operator (CMA) hardens kube-rbac-proxy
   with a static authorization policy that only allows tokens from specific system
   ServiceAccounts (e.g., openshift-monitoring/prometheus-k8s). External bearer tokens
   from Kubernetes Secrets are rejected with 401 Unauthorized, even with proper RBAC
   ClusterRoles. This is a cluster-level security constraint, not an RBAC issue.

   SOLUTION: Pod-native projected tokens
   ======================================
   Instead of external bearer tokens (which kube-rbac-proxy rejects), we use projected
   service account tokens native to the pod. The keda-operator ServiceAccount gets
   cluster-monitoring-view RBAC, allowing its projected token to query Prometheus.
   A local proxy intercepts KEDA's HTTP requests and adds the pod's own token, which
   is always trusted by kube-rbac-proxy. This pattern matches how other cluster
   components (e.g., WVA) successfully authenticate to Prometheus on 4.19+.

   SMOKE TEST:
   ===========
   After deployment, verify the proxy is accessible and working:

     # From any pod in the cluster:
     curl -s "http://prometheus-proxy.openshift-keda:8080/api/v1/query?query=node_memory_MemFree_bytes" | head -c 200

     # Expected: JSON response with metrics data (not a 401 or 404 error)

   If the proxy returns 401, check:
     1. prometheus-proxy pod is Running: kubectl get pod -n openshift-keda -l app=prometheus-proxy
     2. keda-operator SA has cluster-monitoring-view role:
        kubectl get clusterrolebinding | grep keda-operator | grep cluster-monitoring-view

   Only rendered when eppKedaSaturation.enabled is true.
   ============================================================================ #}
{% if eppKedaSaturation is defined and eppKedaSaturation.enabled | default(false) %}
{% if fma is defined and fma.enabled | default(false) %}
{% set scale_kind = 'Deployment' %}
{% set scale_name = 'fma-requester-' ~ model_id_label %}
{% set hpa_name = model_id_label ~ '-fma' %}
{% else %}
{% set scale_kind = 'Deployment' %}
{% set scale_name = model_id_label ~ '-decode' %}
{% set hpa_name = model_id_label ~ '-decode' %}
{% endif %}
{% set epp_ns = eppKedaSaturation.namespace | default(namespace.name, true) %}
{% set pool_name = eppKedaSaturation.epp.poolName | default(model_id_label ~ '-router', true) %}
{% set prom_proxy_url = eppKedaSaturation.prometheus.proxyUrl | default('http://prometheus-proxy.openshift-keda:8080', true) %}
apiVersion: keda.sh/v1alpha1
kind: ScaledObject
metadata:
  name: {{ hpa_name }}-saturation
  namespace: {{ epp_ns }}
  annotations:
    llm-d.ai/managed: "true"
    llm-d.ai/model-id: "{{ model.name }}"
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: {{ scale_kind }}
    name: {{ scale_name }}
  minReplicaCount: {{ eppKedaSaturation.scaledObject.minReplicas | default(1) }}
  maxReplicaCount: {{ eppKedaSaturation.scaledObject.maxReplicas | default(10) }}
  pollingInterval: {{ eppKedaSaturation.scaledObject.pollingInterval | default(15) }}
  triggers:
  # Pool-average KV cache utilization (0.0–1.0)
  # Queries prometheus-proxy in openshift-keda namespace (configurable via eppKedaSaturation.prometheus.proxyUrl)
  - type: prometheus
    name: kv-cache
    metricType: AverageValue
    metadata:
      serverAddress: "{{ prom_proxy_url }}"
      query: |
        max(inference_pool_average_kv_cache_utilization{name="{{ pool_name }}",namespace="{{ epp_ns }}"})
      threshold: "{{ eppKedaSaturation.scaledObject.kvCacheThreshold | default('0.7') }}"
      activationThreshold: "{{ eppKedaSaturation.scaledObject.activationThreshold | default('0') }}"
  # Pool-average request queue size
  - type: prometheus
    name: queue-size
    metricType: AverageValue
    metadata:
      serverAddress: "{{ prom_proxy_url }}"
      query: |
        max(inference_pool_average_queue_size{name="{{ pool_name }}",namespace="{{ epp_ns }}"})
      threshold: "{{ eppKedaSaturation.scaledObject.queueSizeThreshold | default('2') }}"
      activationThreshold: "{{ eppKedaSaturation.scaledObject.activationThreshold | default('0') }}"
{% if eppKedaSaturation.scaledObject.behavior is defined %}
  advanced:
    horizontalPodAutoscalerConfig:
      behavior:
{{ eppKedaSaturation.scaledObject.behavior | toyaml | indent(6, first=True) }}
{% endif %}
{% endif %}
